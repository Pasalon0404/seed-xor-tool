// ---- Tool 8: Encrypted Notes (notes_*) ----

let notes_state = {
    currentTab: 'editor',
    loadedFile: null
};

function notes_switchTab(tab) {
    notes_state.currentTab = tab;
    document.getElementById('notes-tab-editor').style.display = tab === 'editor' ? 'block' : 'none';
    document.getElementById('notes-tab-load').style.display = tab === 'load' ? 'block' : 'none';
}

function notes_toggleEncryption() {
    const area = document.getElementById('notes-password-area');
    const checked = document.getElementById('notes-encrypt-checkbox').checked;
    area.style.display = checked ? 'block' : 'none';
}

function notes_save() {
    const filename = document.getElementById('notes-filename').value || 'notes.txt';
    const content = document.getElementById('notes-editor').value;
    const isEncrypted = document.getElementById('notes-encrypt-checkbox').checked;
    const password = document.getElementById('notes-password').value;

    if (isEncrypted && !password) {
        showStatus('Password required for encryption.', 'error');
        return;
    }

    showStatus(`Note saved as ${filename}${isEncrypted ? ' (encrypted)' : ''}.`, 'success');
}

function notes_download() {
    const filename = document.getElementById('notes-filename').value || 'notes.txt';
    const content = document.getElementById('notes-editor').value;
    const blob = new Blob([content], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    URL.revokeObjectURL(url);
}

document.getElementById('notes-file-input')?.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (file) {
        document.getElementById('notes-decrypt-area').style.display = 'block';
    }
});

function notes_load() {
    const password = document.getElementById('notes-decrypt-password').value;
    if (!password) {
        showStatus('Password required.', 'error');
        return;
    }

    const content = 'Decrypted content placeholder';
    document.getElementById('notes-loaded-text').value = content;
    document.getElementById('notes-loaded-content').style.display = 'block';
    showStatus('File decrypted and loaded.', 'success');
}

// ---- Tool 9: Visual Designer (des_*) ----
// This tool is mostly static SVG, minimal JavaScript needed
